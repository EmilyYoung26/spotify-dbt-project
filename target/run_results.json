bility,\n    energy,\n    tempo,\n    duration_ms,\n\n    \n  safe_divide(cast(duration_ms as float64), 60000)\n as duration_minutes\n\n    from cleaned\n)\n\nselect * from final", "relation_name": "`emilys-analytics`.`spotify_analytics`.`stg_tracks`", "batch_results": null}], "elapsed_time": 2.3116343021392822, "args": {"populate_cache": true, "vars": {}, "require_ref_searches_node_package_before_root": false, "require_yaml_configuration_for_mf_time_spines": false, "log_format": "default", "warn_error_options": {"error": [], "warn": [], "silence": []}, "show_resource_report": false, "profiles_dir": "/Users/emilyyoung/.dbt", "require_explicit_package_overrides_for_builtin_materializations": true, "require_resource_names_without_spaces": true, "defer": false, "quiet": false, "printer_width": 80, "require_nested_cumulative_type_params": false, "skip_nodes_if_on_run_start_fails": false, "introspect": true, "exclude": [], "upload_to_artifacts_ingest_api": false, "which": "run", "strict_mode": false, "require_batched_execution_for_custom_microbatch_strategy": false, "use_colors": true, "print": true, "project_dir": "/Users/emilyyoung/spotify-dbt-project/spotify_analytics", "invocation_command": "dbt run --select stg_tracks", "validate_macro_args": false, "source_freshness_run_project_hooks": true, "version_check": true, "log_level_file": "debug", "select": ["stg_tracks"], "state_modified_compare_more_unrendered_values": false, "show_all_deprecations": false, "require_all_warnings_handled_by_warn_error": false, "favor_state": false, "require_unique_project_resource_names": false, "write_json": true, "log_path": "/Users/emilyyoung/spotify-dbt-project/spotify_analytics/logs", "partial_parse": true, "static_parser": true, "send_anonymous_usage_stats": true, "log_file_max_bytes": 10485760, "cache_selected_only": false, "empty": false, "require_generic_test_arguments_property": true, "use_fast_test_edges": false, "use_colors_file": true, "partial_parse_file_diff": true, "state