    -- keep our float64 values together. 
    cast(danceability as float64) as danceability,
    cast(energy as float64) as energy,
    cast(tempo as float64) as tempo

  from deduped
),

final as (

  select
    track_id,
    track_name,
    artists,
    album_name,
    genre,
    popularity,
    danceability,
    energy,
    tempo,
    duration_ms,

    
  safe_divide(cast(duration_ms as float64), 60000)
 as duration_minutes

    from cleaned
)

select * from final
  ) _dbt_internal_unit_test_actual
),
-- Build expected result
dbt_internal_unit_test_expected as (
  select
    `track_id`, `duration_minutes`, '''expected''' as `actual_or_expected`
  from (
    select safe_cast('''t1''' as STRING) as `track_id`, safe_cast(3.0 as FLOAT64) as `duration_minutes`
  ) _dbt_internal_unit_test_expected
)
-- Union actual and expected results
select * from dbt_internal_unit_test_actual
union all
select * from dbt_internal_unit_test_expected
